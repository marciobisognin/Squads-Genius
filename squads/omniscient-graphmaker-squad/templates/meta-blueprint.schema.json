  "required": [
    "classification",
    "metrics",
    "dag",
    "safeguards"
  ],
  "properties": {
    "classification": {
      "type": "string"
    },
    "metrics": {
      "type": "object"
    },
    "dag": {
      "type": "array"
    },
    "safeguards": {
      "type": "object"
    }
  }
}