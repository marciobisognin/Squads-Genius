{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "squad-docente-iffar.avaliacao_rubrica.schema.json",
  "title": "Instrumento de avaliação e rubrica",
  "type": "object",
  "required": ["componente_id", "objetivo_aprendizagem", "tipo", "criterios", "status_homologacao"],
  "properties": {
    "componente_id": { "type": "string" },
    "objetivo_aprendizagem": { "type": "string" },
    "tipo": { "enum": ["prova", "trabalho", "projeto", "seminario", "lista"] },
    "enunciado": { "type": "string" },
    "criterios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["criterio", "niveis"],
        "properties": {
          "criterio": { "type": "string" },
          "niveis": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["descricao", "pontuacao"],
              "properties": {
                "descricao": { "type": "string" },
                "pontuacao": { "type": "number" }
              }
            }
          }
        }
      }
    },
    "feedback_formativo": { "type": "string" },
    "status_homologacao": { "enum": ["rascunho", "em_revisao", "homologado", "devolvido"] }
  },
  "additionalProperties": true
}
