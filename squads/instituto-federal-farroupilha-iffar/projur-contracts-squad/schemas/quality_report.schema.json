{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "quality_report",
  "type": "object",
  "properties": {
    "passed": {
      "type": "boolean"
    },
    "metricas": {
      "type": "object"
    },
    "gates": {
      "type": "object"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checksums": {
      "type": "object"
    }
  },
  "required": [
    "passed",
    "gates"
  ]
}