      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "source_agent": {
      "type": "string"
    },
    "destination_agent": {
      "type": "string"
    },
    "capability_required": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "idempotency_key": {
      "type": "string"
    },
    "priority": {
      "type": "string"
    },
    "deadline": {
      "type": "string"
    },
    "data_classification": {
      "type": "string"
    },
    "policy_decision": {
      "type": "string"
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
