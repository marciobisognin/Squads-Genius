{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VÉRTICE-OS Canonical Agent Envelope",
  "type": "object",
  "required": [
    "message_id",
    "run_id",
    "project_id",
    "tenant_id",
    "source_agent",
    "destination_agent",
    "capability_required",
    "schema_version",
    "idempotency_key",
    "priority",
    "deadline",
    "data_classification",
    "policy_decision",
    "artifact_refs",
    "qa_status",
    "trace_id",
    "signature"
  ],
