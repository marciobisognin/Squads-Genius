{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://squads-genius/forge-of-solus-prime/briefing.schema.json",
  "title": "Briefing (estrato TÉLOS)",
  "type": "object",
  "required": ["project_name", "objective"],
  "properties": {
    "project_name": {"type": "string"},
    "objective": {"type": "string"},
    "problem": {"type": "string"},
    "target_audience": {"type": "string"},
    "expected_outputs": {"type": "array", "items": {"type": "string"}},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "integrations": {"type": "array", "items": {"type": "string"}},
    "security_level": {"type": "string", "enum": ["low", "medium", "high"]},
    "human_approval_requirements": {"type": "array", "items": {"type": "string"}},
    "success_metrics": {"type": "array", "items": {"type": "string"}},
    "budget_limit": {
      "type": "object",
      "properties": {
        "tokens": {"type": "integer", "minimum": 0},
        "money": {"type": "number", "minimum": 0},
        "time_minutes": {"type": "integer", "minimum": 0}
      }
    },
    "preferred_models": {"type": "array", "items": {"type": "string"}},
    "autonomy_level": {"type": "string", "enum": ["L1", "L2", "L3"]},
    "cynefin_hint": {"type": "string", "enum": ["clear", "complicated", "complex", "chaotic"]}
  },
  "additionalProperties": true
}
